.schedule-page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  background: #f5f7fa;
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  gap: 16rpx;
}

.nav {
  flex: 1;
  height: 72rpx;
  font-size: 26rpx;
  margin: 0;
  line-height: 72rpx;
}

.nav::after,
.guest-btn::after {
  border: none;
}

.month {
  flex: 1.5;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  color: var(--text-main);
  white-space: nowrap;
}

.guest {
  padding: 32rpx;
}

.guest-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-main);
}

.guest-text {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

.guest-btn {
  margin-top: 24rpx;
  height: 96rpx;
  font-size: 30rpx;
}

.calendar {
  padding: 20rpx;
}

.week-header {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.week-cell {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-secondary);
  line-height: 36rpx;
}

.grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 8rpx;
}

.day-cell {
  min-height: 92rpx;
  border-radius: 14rpx;
  background: #f9fafb;
  border: 1px solid transparent;
  padding: 10rpx 8rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.day-cell.empty {
  background: transparent;
  border-color: transparent;
}

.day-content {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.day-no {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-main);
}

.day-meta {
  min-height: 28rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meta-chip {
  height: 28rpx;
  line-height: 28rpx;
  border-radius: 14rpx;
  padding: 0 8rpx;
  font-size: 18rpx;
  text-align: center;
  color: #ffffff;
}

.meta-chip.ledger {
  background: #10b981;
}

.meta-chip.schedule {
  background: #3b82f6;
}

.day-cell:active {
  background: #f3f4f6;
}

.day-cell.active {
  background: #eff6ff;
  border-color: #bfdbfe;
}

.day-cell.today {
  border-color: #93c5fd;
}

.detail {
  padding: 32rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 24rpx;
  color: var(--text-main);
}

.section {
  margin-top: 18rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 8rpx;
}

/* Items in detail list */
.schedule-item {
  padding: 24rpx;
  background: #f9fafb;
  border-radius: 16rpx;
  margin-bottom: 16rpx; 
}

.schedule-item-title {
  font-size: 28rpx;
  font-weight: 600;
}

.item-row {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
  background: #f7f8fb;
  border-radius: 12rpx;
  padding: 14rpx;
  margin-top: 8rpx;
}

.amount {
  font-size: 24rpx;
  font-weight: 700;
  color: #111827;
  white-space: nowrap;
}

.item-main {
  flex: 1;
  min-width: 0;
}

.item-content {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
  line-height: 1.4;
}

.item-time {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.status {
  font-size: 20rpx;
  border-radius: 999rpx;
  padding: 6rpx 12rpx;
  height: fit-content;
  white-space: nowrap;
}

.status.ok {
  color: #166534;
  background: #dcfce7;
}

.status.pending {
  color: #9a3412;
  background: #ffedd5;
}

.status.cancel {
  color: #374151;
  background: #e5e7eb;
}
