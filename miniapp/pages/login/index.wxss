/* ═══════════════════════════════════
   登录页 — Login
   ═══════════════════════════════════ */
.login-page {
  min-height: 100vh;
  padding: 48rpx 36rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 48rpx);
  box-sizing: border-box;
  display: flex; flex-direction: column; justify-content: center;
  background: var(--c-bg);
}

/* ── Brand ── */
.brand { text-align: center; margin-bottom: 36rpx; }
.logo-box {
  width: 128rpx; height: 128rpx; margin: 0 auto 28rpx;
  border-radius: var(--r-xl);
  background: linear-gradient(135deg, var(--c-primary) 0%, #6b8af9 100%);
  color: #fff; display: flex; align-items: center; justify-content: center;
  font-size: 48rpx; font-weight: 800; letter-spacing: 2rpx;
  box-shadow: 0 8rpx 32rpx rgba(79,110,247,0.25);
}
.brand-title { font-size: 38rpx; font-weight: 800; color: var(--c-text); margin-bottom: 12rpx; }
.brand-sub { font-size: 25rpx; color: var(--c-text-3); line-height: 1.5; }

/* ── Form ── */
.form-card { padding: 36rpx 32rpx; }

.nick-input {
  height: 96rpx; border-radius: var(--r-lg);
  background: var(--c-bg); padding: 0 28rpx;
  margin-bottom: 28rpx; font-size: 28rpx; color: var(--c-text);
  border: 1rpx solid var(--c-border-light);
}

.login-btn { height: 96rpx; font-size: 31rpx; margin-bottom: 18rpx; }
.back-btn  { height: 92rpx; font-size: 29rpx; }
.login-btn::after, .back-btn::after { border: none; }

.error-box {
  margin-top: 24rpx; background: #fef2f2; color: #ef4444;
  border-radius: var(--r-md); padding: 20rpx; font-size: 25rpx;
  line-height: 1.5; text-align: center;
}
