.login-page {
  min-height: 100vh;
  padding: 48rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 48rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: #f5f7fa;
}

.logo {
  padding: 48rpx 40rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.logo-mark {
  width: 144rpx;
  height: 144rpx;
  margin: 0 auto 32rpx;
  border-radius: 32rpx;
  background: #111827;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 800;
}

.title {
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 16rpx;
  color: var(--text-main);
}

.subtitle {
  font-size: 26rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.form {
  padding: 32rpx;
}

.input {
  height: 100rpx;
  border-radius: 20rpx;
  background: #f9fafb;
  padding: 0 32rpx;
  margin-bottom: 32rpx;
  border: 1px solid #e5e7eb;
}

.login-btn {
  height: 100rpx;
  font-size: 32rpx;
  margin-bottom: 20rpx;
}

.guest-btn {
  height: 96rpx;
  font-size: 30rpx;
}

.login-btn::after,
.guest-btn::after {
  border: none;
}

.error {
  margin-top: 24rpx;
  background: #fef2f2;
  color: #ef4444;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 26rpx;
  line-height: 1.5;
  text-align: center;
}
