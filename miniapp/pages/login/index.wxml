<view class="login-page">
  <view class="logo card">
    <view class="logo-mark">PAI</view>
    <view class="title">微信小程序客户端</view>
    <view class="subtitle text-muted">登录后可多端同步数据</view>
  </view>

  <view class="form card">
    <input
      class="input"
      placeholder="可选昵称（首次登录会写入）"
      value="{{nickname}}"
      maxlength="20"
      bindinput="onNicknameInput"
    />

    <button class="btn-primary login-btn" loading="{{loading}}" disabled="{{loading}}" bindtap="onLogin">
      微信一键登录
    </button>
    <button class="btn-secondary guest-btn" bindtap="onBackHome">返回首页</button>

    <view wx:if="{{error}}" class="error">{{error}}</view>
  </view>
</view>
