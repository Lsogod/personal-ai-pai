.feedback-page {
  min-height: 100vh;
  padding: 24rpx 28rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  background: var(--c-bg);
}

.head-card,
.form-card,
.tips-card {
  padding: 24rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--c-text);
}

.sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--c-text-3);
}

.mini-btn {
  margin-top: 14rpx;
  width: 260rpx;
  height: 68rpx;
  line-height: 68rpx;
  font-size: 24rpx;
}

.label {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--c-text);
}

.textarea {
  margin-top: 12rpx;
  width: 100%;
  height: 300rpx;
  border: 1rpx solid var(--c-border-light);
  border-radius: var(--r-md);
  background: var(--c-bg);
  padding: 18rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: var(--c-text);
  line-height: 1.6;
}

.helper {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--c-text-3);
  line-height: 1.5;
}

.submit-btn {
  margin-top: 18rpx;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 28rpx;
}

.tips-title {
  font-size: 25rpx;
  font-weight: 700;
  color: var(--c-text-2);
}

.tips-item {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: var(--c-text-3);
  line-height: 1.6;
}
