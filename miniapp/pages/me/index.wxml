<view class="me-page">
  <view class="profile-shell" wx:if="{{authed && profile}}">
    <view class="profile-head">
      <view class="avatar-circle">📋</view>
    </view>
    <view class="card profile-card">
      <view class="name">{{profile.nickname || '用户'}}</view>
      <view class="idline">{{profile.platform || 'miniapp'}} · 阶段 {{profile.setup_stage}}</view>
    </view>
  </view>

  <view class="card section" wx:if="{{!authed}}">
    <view class="title">我的</view>
    <view class="text-muted">登录后可查看技能、绑定账号和订阅提醒。</view>
    <button class="btn-primary action-btn" bindtap="onGoLogin">微信登录</button>
  </view>

  <view class="card menu-card">
    <view class="menu-row" bindtap="onOpenSkills">
      <view class="menu-left">
        <text class="menu-ico">🧩</text>
        <text class="menu-text">技能管理</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-divider"></view>

    <view class="menu-row" bindtap="onOpenBinding">
      <view class="menu-left">
        <text class="menu-ico">🔗</text>
        <text class="menu-text">账号绑定</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <button wx:if="{{authed}}" class="logout" bindtap="onLogout">退出登录</button>
</view>
