.me-page {
  min-height: 100vh;
  padding: 16rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.profile,
.section {
  padding: 20rpx;
}

.name {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.sub {
  color: #6b7280;
  font-size: 24rpx;
  margin-top: 4rpx;
}

.title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.identity-row {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #eceff3;
  font-size: 24rpx;
}

.input {
  height: 84rpx;
  border-radius: 14rpx;
  background: #f3f4f6;
  padding: 0 20rpx;
}

.action-btn {
  margin-top: 12rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
}

.code-wrap {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.code {
  font-size: 36rpx;
  letter-spacing: 6rpx;
  font-weight: 700;
}

.mini-btn {
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  border-radius: 12rpx;
}

.logout {
  margin-top: 8rpx;
  background: #fff;
  border: 1rpx solid #e5e7eb;
  color: #111827;
  border-radius: 14rpx;
}
