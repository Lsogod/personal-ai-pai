.me-page {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  background: #f5f7fa;
}

.profile-shell {
  position: relative;
  margin-top: 16rpx;
}

.profile-head {
  height: 24rpx;
  background: transparent;
  border-radius: 20rpx;
}

.avatar-circle {
  position: absolute;
  left: 50%;
  top: -10rpx;
  transform: translateX(-50%);
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: #ffffff;
  border: 4rpx solid #dbeafe;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.profile-card {
  margin-top: 10rpx;
  padding: 36rpx 24rpx 26rpx;
  text-align: center;
}

.name {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-main);
}

.idline,
.ai-line {
  margin-top: 12rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.section {
  padding: 28rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  color: var(--text-main);
}

.action-btn {
  width: 100%;
  height: 88rpx;
  font-size: 28rpx;
  line-height: 88rpx;
  margin-top: 18rpx;
}

.action-btn::after {
  border: none;
}

.menu-card {
  padding: 0 24rpx;
}

.menu-row {
  height: 108rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.menu-ico {
  font-size: 34rpx;
  width: 40rpx;
  text-align: center;
}

.menu-text {
  font-size: 30rpx;
  color: var(--text-main);
}

.menu-arrow {
  font-size: 42rpx;
  color: #9ca3af;
  line-height: 1;
}

.menu-divider {
  height: 1rpx;
  background: #eceff3;
}

.logout {
  margin-top: 8rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #ffffff;
  color: #111827;
  border-radius: 16rpx;
  border: 2rpx solid #e5e7eb;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout::after {
  border: none;
}
