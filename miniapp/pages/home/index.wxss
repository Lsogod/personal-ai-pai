.home-page {
  min-height: 100vh;
  padding: 0 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 36rpx;
}

.hero {
  margin-top: calc(env(safe-area-inset-top) + 56rpx);
  padding: 48rpx 36rpx 44rpx;
  background: linear-gradient(145deg, var(--c-primary) 0%, #6b8af9 55%, #8ba4fb 100%);
  border-radius: var(--r-xl);
  color: #fff;
  position: relative;
  overflow: hidden;
}

.hero::after {
  content: "";
  position: absolute;
  right: -60rpx;
  top: -60rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius: var(--r-full);
  padding: 8rpx 20rpx;
  margin-bottom: 24rpx;
}

.hero-badge-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #6ee7b7;
}

.hero-badge-text {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.25;
  margin-bottom: 12rpx;
}

.hero-desc {
  font-size: 26rpx;
  opacity: 0.9;
  line-height: 1.6;
  margin-bottom: 36rpx;
}

.hero-actions {
  display: flex;
  gap: 16rpx;
}

.hero-btn {
  flex: 1;
  height: 84rpx;
  font-size: 27rpx;
  border-radius: var(--r-md) !important;
}

.hero-actions .btn-primary {
  background: #fff !important;
  color: var(--c-primary) !important;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12) !important;
  font-weight: 700;
}

.hero-actions .btn-secondary {
  background: rgba(255, 255, 255, 0.18) !important;
  color: #fff !important;
  border-color: rgba(255, 255, 255, 0.3) !important;
}

.section {
  display: flex;
  flex-direction: column;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--c-text);
}

.section-more {
  font-size: 22rpx;
  color: var(--c-primary);
  padding: 6rpx 12rpx;
  border-radius: var(--r-full);
  background: var(--c-primary-light);
}

.entry-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.entry-card {
  padding: 22rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.entry-card:active {
  transform: scale(0.98);
}

.entry-icon-img {
  width: 36rpx;
  height: 36rpx;
}

.entry-name {
  font-size: 25rpx;
  color: var(--c-text-2);
  font-weight: 700;
}

.entry-desc {
  font-size: 20rpx;
  color: var(--c-text-4);
}

.cap-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.cap-card {
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.cap-card:active {
  transform: scale(0.98);
}

.cap-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cap-icon-img {
  width: 34rpx;
  height: 34rpx;
}

.cap-icon-blue {
  background: #ebeffe;
}

.cap-icon-pink {
  background: #fce7f3;
}

.cap-icon-green {
  background: #d1fae5;
}

.cap-icon-amber {
  background: #fef3c7;
}

.cap-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--c-text);
}

.cap-desc {
  font-size: 22rpx;
  color: var(--c-text-3);
  line-height: 1.5;
}

.footer {
  margin-top: auto;
  padding: 32rpx 0 16rpx;
  text-align: center;
}

.footer-text {
  font-size: 22rpx;
  color: var(--c-text-4);
}

.popup-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.38);
  z-index: 390;
}

.popup-card {
  position: fixed;
  left: 50%;
  top: 46%;
  transform: translate(-50%, -50%);
  width: 620rpx;
  max-width: calc(100vw - 64rpx);
  z-index: 400;
  padding: 28rpx 24rpx 24rpx;
}

.popup-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text);
}

.popup-content {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: var(--c-text-2);
  line-height: 1.65;
  white-space: pre-wrap;
}

.popup-actions {
  margin-top: 24rpx;
}

.popup-btn {
  height: 78rpx;
  border-radius: var(--r-md) !important;
}
