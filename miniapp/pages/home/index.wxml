<view class="home-page safe-bottom">
  <view class="hero">
    <view class="hero-badge">
      <text class="hero-badge-dot"></text>
      <text class="hero-badge-text">PAI</text>
    </view>
    <view class="hero-title">你的个人效率工具</view>
    <view class="hero-desc">管理记账与日程提醒，信息同步更清晰。</view>
    <view class="hero-actions">
      <button class="btn-primary hero-btn" bindtap="onOpenCommand">
        <text>打开指令面板</text>
      </button>
      <button class="btn-secondary hero-btn" bindtap="onOpenMe">
        <text>个人中心</text>
      </button>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">常用入口</text>
    </view>
    <view class="entry-grid">
      <view class="entry-card card" bindtap="onQuickAddLedger">
        <image class="entry-icon-img" src="/assets/icons/ic-receipt.svg" mode="aspectFit" />
        <text class="entry-name">记一笔</text>
        <text class="entry-desc">跳到账单新增</text>
      </view>
      <view class="entry-card card" bindtap="onQuickAddSchedule">
        <image class="entry-icon-img" src="/assets/icons/ic-calendar.svg" mode="aspectFit" />
        <text class="entry-name">新增日程</text>
        <text class="entry-desc">跳转日程新增</text>
      </view>
      <view class="entry-card card" bindtap="onOpenMe">
        <image class="entry-icon-img" src="/assets/icons/ic-user.svg" mode="aspectFit" />
        <text class="entry-name">我的</text>
        <text class="entry-desc">账号与设置</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">核心能力</text>
      <view class="section-more" bindtap="onOpenCapabilitiesDetail">查看详情</view>
    </view>
    <view class="cap-grid">
      <view class="cap-card card" bindtap="onOpenCapabilitiesDetail">
        <view class="cap-icon cap-icon-blue">
          <image class="cap-icon-img" src="/assets/icons/ic-receipt.svg" mode="aspectFit" />
        </view>
        <text class="cap-name">账单管理</text>
        <text class="cap-desc">支持分类、筛选、统计和趋势查看。</text>
      </view>
      <view class="cap-card card" bindtap="onOpenCapabilitiesDetail">
        <view class="cap-icon cap-icon-pink">
          <image class="cap-icon-img" src="/assets/icons/ic-clock.svg" mode="aspectFit" />
        </view>
        <text class="cap-name">日程提醒</text>
        <text class="cap-desc">快速创建提醒并可跟踪执行状态。</text>
      </view>
      <view class="cap-card card" bindtap="onOpenCapabilitiesDetail">
        <view class="cap-icon cap-icon-green">
          <image class="cap-icon-img" src="/assets/icons/ic-sync.svg" mode="aspectFit" />
        </view>
        <text class="cap-name">多端同步</text>
        <text class="cap-desc">小程序与 Web 账号支持绑定互通。</text>
      </view>
      <view class="cap-card card" bindtap="onOpenCapabilitiesDetail">
        <view class="cap-icon cap-icon-amber">
          <image class="cap-icon-img" src="/assets/icons/ic-tools.svg" mode="aspectFit" />
        </view>
        <text class="cap-name">问题反馈</text>
        <text class="cap-desc">可在个人中心提交建议与版本反馈。</text>
      </view>
    </view>
  </view>

  <view class="footer">
    <text class="footer-text">PAI · 个人效率工具</text>
  </view>

  <block wx:if="{{showPopup && popupConfig}}">
    <view class="popup-mask" catchtap="onClosePopup"></view>
    <view class="popup-card card">
      <view class="popup-title">{{popupConfig.title || '系统公告'}}</view>
      <view class="popup-content">{{popupConfig.content}}</view>
      <view class="popup-actions">
        <button class="btn-primary popup-btn" bindtap="onClosePopup">
          {{popupConfig.primary_button_text || '我知道了'}}
        </button>
      </view>
    </view>
  </block>
</view>
