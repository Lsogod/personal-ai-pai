<view class="chat-page">
  <view wx:if="{{sidebarOpen}}" class="sidebar-mask show" bindtap="onCloseSidebar"></view>
  <view class="conv-sidebar {{sidebarOpen ? 'open' : ''}}" catchtap="stopTap">
    <view class="conv-header">
      <view class="conv-title-wrap">
        <image class="conv-title-icon" src="/assets/icons/chat.svg" mode="aspectFit" />
        <text class="conv-title">任务记录</text>
      </view>
      <view class="conv-add-btn" bindtap="onNewConversation">
        <text>新建</text>
      </view>
    </view>
    <scroll-view class="conv-list" scroll-y="true">
      <view wx:if="{{loadingConversations}}" class="conv-empty">加载中...</view>
      <view wx:elif="{{conversations.length === 0}}" class="conv-empty">暂无历史记录</view>
      <view
        wx:for="{{conversations}}"
        wx:key="id"
        class="conv-item {{item.active ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onSwitchConversation"
      >
        <view class="conv-item-title">{{item.title}}</view>
        <view class="conv-item-meta">{{item.summary || '暂无摘要'}}</view>
        <view class="conv-item-time">
          <image class="conv-time-icon" src="/assets/icons/tab-calendar.svg" mode="aspectFit" />
          <text>{{item.lastText}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="notify-stack" wx:if="{{notifyCards.length > 0}}">
    <view class="notify-card" wx:for="{{notifyCards}}" wx:key="id">
      <view class="notify-title-row">
        <text class="notify-title" user-select="true">日程提醒</text>
        <text class="notify-close" user-select="true" data-id="{{item.id}}" bindtap="onDismissNotify">关闭</text>
      </view>
      <view class="notify-content">{{item.content}}</view>
      <view class="notify-time">{{item.timeText}}</view>
    </view>
  </view>

  <view class="header">
    <view class="header-main">
      <view class="ai-info">
        <text class="ai-name fade-in" user-select="true">任务面板</text>
        <view class="status-dot {{wsOpen ? 'online' : 'offline'}}"></view>
      </view>
      <view class="header-actions">
        <view class="conv-toggle-btn" bindtap="onToggleSidebar">
          <image class="conv-toggle-icon" src="/assets/icons/chat.svg" mode="aspectFit" />
          <text>记录</text>
        </view>
      </view>
    </view>
    <view class="assistant-caption" wx:if="{{profile}}">
      <text>{{profile.nickname || '用户'}} · 个人效率工具</text>
    </view>
    <view class="stats-row" wx:if="{{authed}}">
      <view class="stat-tag">支出 ¥{{stats.total || 0}}</view>
      <view class="stat-tag">账单 {{stats.count || 0}}</view>
    </view>
    <view class="guest-banner" wx:else bindtap="onGoLogin">
      <text user-select="true">未登录模式 · 点击同步数据</text>
    </view>
  </view>

  <view class="task-board">
    <view class="task-title">快捷操作</view>
    <view class="task-grid">
      <view class="task-card" data-template="今天午饭30元，分类餐饮" bindtap="onUseTemplate">
        <view class="task-card-title">快速记账</view>
        <view class="task-card-desc">例如：午饭30</view>
      </view>
      <view class="task-card" data-template="明天14:00提醒我开会" bindtap="onUseTemplate">
        <view class="task-card-title">新增提醒</view>
        <view class="task-card-desc">例如：30分钟后提醒我喝水</view>
      </view>
      <view class="task-card" data-template="查看今天账单" bindtap="onUseTemplate">
        <view class="task-card-title">查询账单</view>
        <view class="task-card-desc">按天/周/月汇总</view>
      </view>
      <view class="task-card" data-template="查看本周日程，按状态区分已完成和未完成" bindtap="onUseTemplate">
        <view class="task-card-title">查询日程</view>
        <view class="task-card-desc">待办 / 已完成 / 已取消</view>
      </view>
    </view>
    <view class="task-suggest-row">
      <view class="task-suggest-chip" data-template="识别这张支付截图并记账" bindtap="onUseTemplate">截图识别记账</view>
      <view class="task-suggest-chip" data-template="今天是否有待办提醒" bindtap="onUseTemplate">检查待办</view>
      <view class="task-suggest-chip" data-template="汇总最近账单" bindtap="onUseTemplate">账单汇总</view>
    </view>
  </view>

  <view class="msg-list">
    <view
      wx:for="{{messages}}"
      wx:key="index"
      id="msg-{{index}}"
      class="msg-row {{item.role === 'user' ? 'right' : 'left'}}"
    >
      <view class="avatar" wx:if="{{item.role !== 'user'}}">
         <view class="avatar-default">
           <text class="avatar-text">P</text>
         </view>
      </view>
      <view class="bubble {{item.role === 'user' ? 'bubble-user' : 'bubble-sys'}}">
        <view wx:if="{{item.image_urls && item.image_urls.length > 0}}" class="bubble-images">
          <image
            wx:for="{{item.image_urls}}"
            wx:for-item="imgUrl"
            wx:for-index="imgIdx"
            wx:key="imgIdx"
            class="bubble-image"
            src="{{imgUrl}}"
            mode="aspectFill"
            bindload="onBubbleMediaLoad"
            data-src="{{imgUrl}}"
            bindtap="onPreviewBubbleImage"
          />
        </view>
        <rich-text wx:if="{{item.role === 'assistant'}}" class="bubble-rich" nodes="{{item.content_nodes}}"></rich-text>
        <text wx:else class="bubble-text" user-select="true" selectable="true">{{item.content}}</text>
      </view>
    </view>
    <view wx:if="{{pendingState}}" class="msg-row left msg-row-pending">
      <view class="avatar">
        <view class="avatar-default">
          <text class="avatar-text">P</text>
        </view>
      </view>
      <view class="bubble bubble-sys bubble-pending">
        <view class="typing-line">
          <text class="typing-label">处理中</text>
          <view class="typing-dots">
            <text class="typing-dot dot-1">•</text>
            <text class="typing-dot dot-2">•</text>
            <text class="typing-dot dot-3">•</text>
          </view>
        </view>
      </view>
    </view>
    <view id="scroll-bottom" style="height: 1rpx;"></view>
  </view>

  <view class="composer-container safe-bottom">
    <view class="preview-area" wx:if="{{selectedImages.length > 0}}">
      <scroll-view class="preview-list" scroll-x="true">
        <view class="preview-inner">
          <view class="preview-item" wx:for="{{selectedImages}}" wx:key="index">
            <image class="preview-image" src="{{item.path}}" mode="aspectFill" data-index="{{index}}" bindtap="onPreviewImage"/>
            <view class="preview-remove" data-index="{{index}}" catchtap="onRemoveImage">
              <text class="remove-icon">×</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="input-area">
      <view class="tool-btn" bindtap="onChooseImage">
        <image class="icon-image" src="/assets/icons/image.svg" mode="aspectFit"/>
      </view>
      <view class="input-wrapper">
        <textarea
          class="input-box"
          placeholder="输入指令，例如：午饭30；明天14:00提醒开会"
          placeholder-style="color: #9ca3af;"
          auto-height="true"
          maxlength="2000"
          cursor-spacing="20"
          confirm-type="send"
          show-confirm-bar="{{true}}"
          value="{{inputText}}"
          bindinput="onInput"
          bindconfirm="onConfirmSend"
        />
      </view>
      <view class="send-btn {{inputText || selectedImages.length > 0 ? 'active' : ''}}" bindtap="onSend">
        <image class="icon-send-img" src="/assets/icons/send.svg" mode="aspectFit"/>
      </view>
    </view>
  </view>
</view>
