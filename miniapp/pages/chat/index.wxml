<view class="chat-page">
  <view class="notify-stack" wx:if="{{notifyCards.length > 0}}">
    <view class="notify-card" wx:for="{{notifyCards}}" wx:key="id">
      <view class="notify-title-row">
        <text class="notify-title">日程提醒</text>
        <text class="notify-close" data-id="{{item.id}}" bindtap="onDismissNotify">关闭</text>
      </view>
      <view class="notify-content">{{item.content}}</view>
      <view class="notify-time">{{item.timeText}}</view>
    </view>
  </view>

  <view class="top card">
    <view class="name">{{profile.ai_name || 'PAI'}} {{profile.ai_emoji || ''}}</view>
    <view class="meta text-muted">{{profile.nickname || '用户'}} · {{wsOpen ? '已连接' : '连接中'}}</view>
    <view class="stats">
      <view class="badge">30天支出 ¥{{stats.total || 0}}</view>
      <view class="badge">账单 {{stats.count || 0}} 笔</view>
    </view>
  </view>

  <scroll-view class="msg-scroll" scroll-y="true" scroll-with-animation="true" scroll-into-view="{{scrollIntoView}}">
    <view class="msg-list">
      <view
        wx:for="{{messages}}"
        wx:key="index"
        id="msg-{{index}}"
        class="msg-row {{item.role === 'user' ? 'right' : 'left'}}"
      >
        <view class="bubble {{item.role === 'user' ? 'bubble-user' : 'bubble-ai'}}">
          <text class="bubble-text">{{item.content}}</text>
          <view wx:if="{{item.image_urls && item.image_urls.length > 0}}" class="bubble-images">
            <image
              wx:for="{{item.image_urls}}"
              wx:key="index"
              class="bubble-image"
              src="{{item}}"
              mode="aspectFill"
            />
          </view>
          <text class="time">{{item.created_at ? item.created_at.slice(11,16) : ''}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="composer card">
    <scroll-view class="preview-list" scroll-x="true" wx:if="{{selectedImages.length > 0}}">
      <view class="preview-inner">
        <view class="preview-item" wx:for="{{selectedImages}}" wx:key="index">
          <image class="preview-image" src="{{item.path}}" mode="aspectFill" data-index="{{index}}" bindtap="onPreviewImage"/>
          <view class="preview-remove" data-index="{{index}}" bindtap="onRemoveImage">×</view>
        </view>
      </view>
    </scroll-view>

    <view class="compose-row">
      <button class="pick-btn" bindtap="onChooseImage">图</button>
      <textarea
        class="input"
        placeholder="输入消息..."
        auto-height="true"
        maxlength="2000"
        value="{{inputText}}"
        bindinput="onInput"
      />
      <button class="send-btn" loading="{{sending}}" disabled="{{sending}}" bindtap="onSend">发送</button>
    </view>
  </view>
</view>
