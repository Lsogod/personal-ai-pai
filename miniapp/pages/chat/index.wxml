<view class="chat-page">
  <!-- Sidebar mask -->
  <view wx:if="{{sidebarOpen}}" class="sidebar-mask show" bindtap="onCloseSidebar"></view>

  <!-- Sidebar -->
  <view class="conv-sidebar {{sidebarOpen ? 'open' : ''}}" catchtap="stopTap">
    <view class="conv-header">
      <text class="conv-title">历史记录</text>
      <view class="conv-add-btn" bindtap="onNewConversation">
        <text>＋ 新建</text>
      </view>
    </view>
    <scroll-view class="conv-list" scroll-y="true">
      <view wx:if="{{loadingConversations}}" class="conv-empty">加载中...</view>
      <view wx:elif="{{conversations.length === 0}}" class="conv-empty">暂无历史记录</view>
      <view
        wx:for="{{conversations}}"
        wx:key="id"
        class="conv-item {{item.active ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="onSwitchConversation"
      >
        <view class="conv-item-body">
          <view class="conv-item-title">{{item.title}}</view>
          <view class="conv-item-meta">{{item.summary || '暂无摘要'}}</view>
          <view class="conv-item-time">{{item.lastText}}</view>
        </view>
        <view class="conv-item-del" data-id="{{item.id}}" catchtap="onDeleteConversation">
          <image class="conv-del-icon" src="/assets/icons/ic-delete-gray.svg" mode="aspectFit" />
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- Notifications -->
  <view class="notify-stack" wx:if="{{notifyCards.length > 0 && !guideVisible}}">
    <view class="notify-card" wx:for="{{notifyCards}}" wx:key="id">
      <view class="notify-head">
        <view class="notify-title">
          <image class="notify-title-icon" src="/assets/icons/ic-clock-white.svg" mode="aspectFit" />
          <text>日程提醒</text>
        </view>
        <view class="notify-close" data-id="{{item.id}}" bindtap="onDismissNotify">
          <image class="notify-close-icon" src="/assets/icons/ic-close.svg" mode="aspectFit" />
        </view>
      </view>
      <view class="notify-body">{{item.content}}</view>
      <view class="notify-time">{{item.timeText}}</view>
    </view>
  </view>

  <!-- Header -->
  <view class="header">
    <view class="header-row">
      <view class="header-left">
        <text class="header-title">指令面板</text>
        <view class="status-dot {{wsOpen ? 'on' : ''}}"></view>
      </view>
      <view class="header-right">
        <view class="history-btn" bindtap="onToggleSidebar">
          <view class="history-btn-text">
            <image class="history-btn-icon" src="/assets/icons/ic-history.svg" mode="aspectFit" />
            <text>记录</text>
          </view>
        </view>
      </view>
    </view>
    <view class="header-sub" wx:if="{{authed}}">
      <text class="header-caption">输入指令 · 自动执行</text>
      <view class="header-stats">
        <text class="stat-pill">¥{{stats.total || 0}}</text>
        <text class="stat-pill">{{stats.count || 0}}笔</text>
      </view>
    </view>
    <view class="guest-bar" wx:else bindtap="onGoLogin">
      <text>未登录 · 点击同步数据</text>
    </view>
  </view>

  <!-- Onboarding -->
  <view class="guide-board card {{(sending || pendingState) ? 'is-waiting' : ''}}" wx:if="{{authed && guideVisible}}">
    <view class="guide-title">{{onboardingTitle || '首次引导'}}</view>
    <view class="guide-sub">{{onboardingHint}}</view>
    <view class="onboarding-chip-list" wx:if="{{onboardingSuggestions.length > 0}}">
      <view
        class="onboarding-chip {{(sending || pendingState) ? 'disabled' : ''}}"
        wx:for="{{onboardingSuggestions}}"
        wx:key="label"
        data-text="{{item.text}}"
        bindtap="onOnboardingUseSuggestion"
      >
        {{item.label}}
      </view>
    </view>
    <view class="onboarding-input-row">
      <input
        class="onboarding-input {{(sending || pendingState) ? 'disabled' : ''}}"
        value="{{onboardingInput}}"
        placeholder="{{onboardingPlaceholder || onboardingDefaultPlaceholder}}"
        placeholder-class="onboarding-placeholder"
        confirm-type="send"
        disabled="{{sending || pendingState}}"
        bindinput="onOnboardingInput"
        bindconfirm="onOnboardingSubmit"
      />
      <button
        class="btn-primary onboarding-send-btn {{(sending || pendingState) ? 'disabled' : ''}}"
        bindtap="onOnboardingSubmit"
        disabled="{{sending || pendingState}}"
        loading="{{sending || pendingState}}"
      >{{onboardingConfirmText}}</button>
    </view>
    <view class="onboarding-waiting" wx:if="{{sending || pendingState}}">
      <view class="wait-dot"></view>
      <text class="onboarding-waiting-text">{{onboardingWaitingText}}</text>
    </view>
  </view>

  <!-- Log stream -->
  <view class="log-list" wx:if="{{!guideVisible}}">
    <!-- Loading skeleton -->
    <view wx:if="{{loadingHistory && messages.length === 0}}" class="log-list">
      <view class="skeleton-entry" wx:for="{{[1,2,3]}}" wx:key="*this">
        <view class="skeleton-cmd"><view class="skeleton-line w60"></view></view>
        <view class="skeleton-result"><view class="skeleton-line w80"></view><view class="skeleton-line w40"></view></view>
      </view>
    </view>
    <view
      wx:for="{{messages}}"
      wx:key="index"
      id="msg-{{index}}"
      class="log-entry"
    >
      <!-- User command -->
      <view wx:if="{{item.role === 'user'}}" class="log-cmd">
        <text class="log-prompt" decode="{{true}}">&gt;</text>
        <view class="log-cmd-body">
          <view wx:if="{{item.image_urls && item.image_urls.length > 0}}" class="log-cmd-images">
            <image
              wx:for="{{item.image_urls}}"
              wx:for-item="imgUrl"
              wx:for-index="imgIdx"
              wx:key="imgIdx"
              class="log-cmd-img"
              src="{{imgUrl}}"
              mode="aspectFill"
              data-src="{{imgUrl}}"
              bindtap="onPreviewBubbleImage"
            />
          </view>
          <text wx:if="{{item.display_content}}" class="log-cmd-text" user-select="true">{{item.display_content}}</text>
        </view>
        <text class="log-time">{{item.timeText}}</text>
      </view>
      <!-- System result -->
      <view wx:else class="log-result-wrap">
        <view class="log-result card">
          <!-- Tool steps: show on last assistant message -->
          <view wx:if="{{toolSteps.length > 0 && index === messages.length - 1}}" class="tool-steps-wrap">
            <view class="tool-steps-header" data-expanded="{{toolStepsExpanded}}" bindtap="onToggleToolSteps">
              <text class="tool-steps-icon">⚡</text>
              <text class="tool-steps-summary" wx:if="{{toolStepsDone}}">已完成 {{toolSteps.length}} 个步骤</text>
              <text class="tool-steps-summary" wx:else>执行中 ({{toolStepsDoneCount}}/{{toolSteps.length}})</text>
              <text class="tool-steps-arrow {{toolStepsExpanded ? 'expanded' : ''}}">›</text>
            </view>
            <view wx:if="{{toolStepsExpanded}}" class="tool-steps-list">
              <view wx:for="{{toolSteps}}" wx:for-item="step" wx:for-index="stepIdx" wx:key="stepIdx" class="tool-step">
                <view class="tool-step-icon {{step.status === 'running' ? 'spinning' : 'done'}}">
                  <text wx:if="{{step.status === 'running'}}">⟳</text>
                  <text wx:else>✓</text>
                </view>
                <text class="tool-step-name">{{step.name}}</text>
              </view>
            </view>
          </view>
          <view wx:if="{{item.image_urls && item.image_urls.length > 0}}" class="log-result-images">
            <image
              wx:for="{{item.image_urls}}"
              wx:for-item="imgUrl"
              wx:for-index="imgIdx"
              wx:key="imgIdx"
              class="bubble-image"
              src="{{imgUrl}}"
              mode="aspectFill"
              bindload="onBubbleMediaLoad"
              data-src="{{imgUrl}}"
              bindtap="onPreviewBubbleImage"
            />
          </view>
          <rich-text class="log-result-rich" nodes="{{item.content_nodes}}"></rich-text>
        </view>
        <text class="log-time log-time-right">{{item.timeText}}</text>
      </view>
    </view>

    <!-- Pending (no tool steps — just thinking dots) -->
    <view wx:if="{{pendingState && toolSteps.length === 0}}" class="log-entry">
      <view class="log-result-wrap">
        <view class="log-result card log-result-pending">
          <view class="typing-line">
            <text class="typing-label">执行中</text>
            <view class="typing-dots">
              <text class="typing-dot dot-1">·</text>
              <text class="typing-dot dot-2">·</text>
              <text class="typing-dot dot-3">·</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view id="scroll-bottom" style="height: 1rpx;"></view>
  </view>

  <!-- Composer -->
  <view class="composer safe-bottom" wx:if="{{authed && !guideVisible}}">
    <view class="preview-area" wx:if="{{selectedImages.length > 0}}">
      <scroll-view class="preview-list" scroll-x="true">
        <view class="preview-inner">
          <view class="preview-item" wx:for="{{selectedImages}}" wx:key="index">
            <image class="preview-image" src="{{item.path}}" mode="aspectFill" data-index="{{index}}" bindtap="onPreviewImage"/>
            <view class="preview-remove" data-index="{{index}}" catchtap="onRemoveImage">
              <text class="remove-x">×</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>
    <view class="input-area">
      <view class="img-btn" bindtap="onChooseImage">
        <image class="icon-img" src="/assets/icons/image.svg" mode="aspectFit"/>
      </view>
      <view class="input-wrap">
        <textarea
          class="input-box"
          placeholder="输入指令：记账、提醒、查询..."
          placeholder-style="color: #b0b6c3;"
          auto-height="true"
          maxlength="2000"
          cursor-spacing="20"
          confirm-type="send"
          show-confirm-bar="{{true}}"
          value="{{inputText}}"
          bindinput="onInput"
          bindconfirm="onConfirmSend"
        />
      </view>
      <view class="send-btn {{inputText || selectedImages.length > 0 ? 'active' : ''}} {{sending ? 'sending' : ''}}" bindtap="onSend">
        <image wx:if="{{!sending}}" class="icon-send" src="/assets/icons/send.svg" mode="aspectFit"/>
        <text wx:else class="icon-send" style="font-size:30rpx;color:#fff;">⟳</text>
      </view>
    </view>
  </view>
</view>
