.chat-page {
  background: #f5f7fa;
  min-height: 100vh;
  position: relative;
}

.sidebar-mask {
  position: fixed;
  inset: 0;
  background: rgba(17, 24, 39, 0.18);
  z-index: 240;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s ease;
}

.sidebar-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.conv-sidebar {
  position: fixed;
  left: 0;
  top: 0;
  bottom: 0;
  width: 82vw;
  min-width: 460rpx;
  max-width: 620rpx;
  background: #ffffff;
  z-index: 260;
  transform: translateX(calc(-100% - 48rpx));
  transition: transform 0.22s ease;
  opacity: 0;
  pointer-events: none;
  box-shadow: 10rpx 0 30rpx rgba(0, 0, 0, 0.12);
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.conv-sidebar.open {
  transform: translateX(0);
  opacity: 1;
  pointer-events: auto;
}

.conv-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: calc(env(safe-area-inset-top) + 24rpx) 24rpx 16rpx;
  border-bottom: 1rpx solid #eef0f4;
}

.conv-title-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.conv-title-icon {
  width: 30rpx;
  height: 30rpx;
  opacity: 0.9;
}

.conv-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
  white-space: nowrap;
}

.conv-add-btn {
  min-width: 96rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: #111827;
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.conv-list {
  flex: 1;
  min-height: 0;
  padding: 8rpx 16rpx 20rpx;
  box-sizing: border-box;
}

.conv-empty {
  padding: 40rpx 20rpx;
  text-align: center;
  color: #9ca3af;
  font-size: 24rpx;
}

.conv-item {
  margin: 10rpx 0;
  border: 1rpx solid #e8edf4;
  border-radius: 16rpx;
  padding: 16rpx;
  background: #fff;
  box-sizing: border-box;
  width: auto;
  max-width: 100%;
  overflow: hidden;
  transition: all 0.18s ease;
}

.conv-item.active {
  border-color: #e8edf4;
  background: #f5f7fb;
  box-shadow: none;
}

.conv-item.active .conv-item-title {
  color: #0f172a;
}

.conv-item-title {
  font-size: 28rpx;
  color: #111827;
  font-weight: 600;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.conv-item-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.45;
  word-break: break-all;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  min-height: 64rpx;
}

.conv-item-time {
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #9ca3af;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.conv-time-icon {
  width: 20rpx;
  height: 20rpx;
  opacity: 0.75;
}

/* Header */
.header {
  position: sticky;
  top: 0;
  padding: 20rpx 32rpx;
  padding-top: calc(env(safe-area-inset-top) + 20rpx);
  background: linear-gradient(180deg, #ffffff 0%, #fafbfc 100%);
  z-index: 100;
  border-bottom: 1rpx solid rgba(0,0,0,0.06);
}

.header-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.ai-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.ai-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  letter-spacing: -0.5rpx;
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.header-actions {
  flex-shrink: 0;
}

.conv-toggle-btn {
  min-width: 98rpx;
  height: 56rpx;
  border-radius: 16rpx;
  border: 1rpx solid #dbe2ea;
  color: #111827;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #fff;
}

.conv-toggle-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.9;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #d1d5db;
  box-shadow: 0 0 0 4rpx rgba(209, 213, 219, 0.3);
}

.status-dot.online {
  background: #10b981;
  box-shadow: 0 0 0 4rpx rgba(16, 185, 129, 0.2);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.guest-banner {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #3b82f6;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.1) 0%, rgba(37, 99, 235, 0.08) 100%);
  border-radius: 12rpx;
  display: inline-flex;
  align-items: center;
  font-weight: 500;
}

.stats-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.stat-tag {
  font-size: 22rpx;
  color: #6b7280;
  background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 500;
}

/* Message List */
.msg-list {
  padding: 20rpx 32rpx;
  padding-bottom: 200rpx;
}

.msg-row {
  display: flex;
  margin-bottom: 28rpx;
  align-items: flex-start;
}

.msg-row.left {
  justify-content: flex-start;
}

.msg-row.right {
  justify-content: flex-end;
}

.avatar {
  margin-right: 16rpx;
  width: 68rpx;
  height: 68rpx;
  flex-shrink: 0;
}

.avatar-emoji,
.avatar-default {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  box-shadow: none;
}

.avatar-emoji {
  color: #111827;
  font-size: 34rpx;
  line-height: 1;
}

.avatar-default {
  background: transparent;
}

.avatar-default-icon {
  width: 34rpx;
  height: 34rpx;
}

.bubble {
  max-width: 75%;
  padding: 24rpx 28rpx;
  position: relative;
  font-size: 30rpx;
  line-height: 1.6;
  word-break: break-word;
}

.bubble-text,
.bubble-rich {
  display: block;
  font-size: 30rpx;
  line-height: 1.6;
  word-break: break-word;
}

.bubble-ai {
  background: #ffffff;
  border-radius: 8rpx 32rpx 32rpx 32rpx;
  color: #111827;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  border: 1rpx solid rgba(0,0,0,0.04);
}

.bubble-user {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  border-radius: 32rpx 32rpx 8rpx 32rpx;
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(37, 99, 235, 0.25);
}

.bubble-images {
  margin-bottom: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.bubble-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
}

.msg-row-pending {
  opacity: 0.96;
}

.bubble-pending {
  min-width: 180rpx;
}

.typing-line {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.typing-label {
  font-size: 28rpx;
  color: #374151;
}

.typing-dots {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.typing-dot {
  font-size: 34rpx;
  line-height: 1;
  color: #6b7280;
  animation: typingBlink 1.1s infinite ease-in-out;
}

.typing-dot.dot-2 {
  animation-delay: 0.16s;
}

.typing-dot.dot-3 {
  animation-delay: 0.32s;
}

@keyframes typingBlink {
  0%, 80%, 100% {
    opacity: 0.2;
    transform: translateY(0);
  }
  40% {
    opacity: 1;
    transform: translateY(-4rpx);
  }
}

/* Composer */
.composer-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255,255,255,0.98);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(0,0,0,0.06);
  padding: 16rpx 24rpx;
  z-index: 200;
  box-sizing: border-box;
}

.preview-area {
  padding-bottom: 20rpx;
}

.preview-list {
  width: 100%;
  white-space: nowrap;
}

.preview-inner {
  display: inline-flex;
  gap: 16rpx;
}

.preview-item {
  position: relative;
}

.preview-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  border: 1px solid rgba(0,0,0,0.05);
}

.preview-remove {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 50%;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
}

.remove-icon {
  font-size: 32rpx;
  line-height: 32rpx;
  margin-top: -4rpx;
}

.input-area {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
}

.tool-btn {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
  color: #6b7280;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.tool-btn:active {
  background: #e5e7eb;
  transform: scale(0.95);
}

.icon-plus {
  font-size: 40rpx;
  font-weight: 400;
  line-height: 1;
}

.input-wrapper {
  flex: 1;
  min-width: 0;
  background: #f3f4f6;
  border-radius: 38rpx;
  padding: 16rpx 24rpx;
  min-height: 76rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(0,0,0,0.04);
}

.input-box {
  width: 100%;
  font-size: 30rpx;
  line-height: 1.5;
  color: #111827;
  padding: 0;
  margin: 0;
  min-height: 44rpx;
  max-height: 200rpx;
}

.send-btn {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #e5e7eb;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.send-btn:active {
  transform: scale(0.95);
}

.send-btn.active {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.3);
}

.icon-send {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
}

.icon-image {
  width: 44rpx;
  height: 44rpx;
}

.icon-send-img {
  width: 36rpx;
  height: 36rpx;
}

/* Notify */
.notify-stack {
  position: fixed;
  top: calc(env(safe-area-inset-top) + 20rpx);
  right: 20rpx;
  z-index: 300;
  width: 500rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notify-card {
  background: rgba(17, 24, 39, 0.9);
  backdrop-filter: blur(4px);
  color: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.15);
  animation: slideIn 0.3s ease-out;
}

@keyframes slideIn {
  from { transform: translateX(100%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

.notify-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.notify-title {
  font-size: 26rpx;
  font-weight: 600;
}

.notify-close {
  font-size: 24rpx;
  opacity: 0.7;
  padding: 8rpx;
}

.notify-content {
  font-size: 28rpx;
  line-height: 1.4;
}

.notify-time {
  margin-top: 10rpx;
  font-size: 22rpx;
  opacity: 0.6;
}
