/* ═══════════════════════════════════
   指令面板 — Chat Page
   ═══════════════════════════════════ */
.chat-page {
  background: var(--c-bg);
  min-height: 100vh;
  position: relative;
}

/* ── Sidebar ── */
.sidebar-mask {
  position: fixed; inset: 0;
  background: rgba(26, 29, 38, 0.2);
  z-index: 240;
  opacity: 0; pointer-events: none;
  transition: opacity 0.2s;
}
.sidebar-mask.show { opacity: 1; pointer-events: auto; }

.conv-sidebar {
  position: fixed; left: 0; top: 0; bottom: 0;
  width: 80vw; max-width: 600rpx;
  background: var(--c-surface);
  z-index: 260;
  transform: translateX(-105%);
  transition: transform 0.24s cubic-bezier(.4,0,.2,1);
  opacity: 0; pointer-events: none;
  box-shadow: 8rpx 0 40rpx rgba(0,0,0,0.08);
  display: flex; flex-direction: column;
  overflow: hidden;
}
.conv-sidebar.open { transform: translateX(0); opacity: 1; pointer-events: auto; }

.conv-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: calc(env(safe-area-inset-top) + 28rpx) 28rpx 20rpx;
  border-bottom: 1rpx solid var(--c-border-light);
}
.conv-title { font-size: 32rpx; font-weight: 700; color: var(--c-text); }
.conv-add-btn {
  height: 56rpx; padding: 0 20rpx; border-radius: var(--r-md);
  background: var(--c-primary); color: #fff; font-size: 24rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center;
}

.conv-list {
  flex: 1; min-height: 0;
  padding: 12rpx 20rpx 20rpx 16rpx;
  overflow: hidden;
  box-sizing: border-box;
}
.conv-empty { padding: 48rpx 20rpx; text-align: center; color: var(--c-text-3); font-size: 24rpx; }

.conv-item {
  display: flex; align-items: center;
  margin: 10rpx 0; padding: 18rpx 20rpx;
  border-radius: var(--r-md); background: var(--c-bg);
  border: 1rpx solid transparent;
  box-sizing: border-box;
  transition: background 0.15s, border-color 0.15s;
  width: 100%;
  max-width: 100%;
  overflow: hidden;
}
.conv-item.active {
  background: var(--c-primary-light);
  border-color: transparent;
  box-shadow: inset 0 0 0 1rpx rgba(79,110,247,0.18);
}
.conv-item-body { flex: 1; min-width: 0; overflow: hidden; }
.conv-item-title { font-size: 27rpx; font-weight: 600; color: var(--c-text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.conv-item-meta { margin-top: 8rpx; font-size: 22rpx; color: var(--c-text-3); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.conv-item-time { margin-top: 8rpx; font-size: 20rpx; color: var(--c-text-4); }

/* ── Delete icon ── */
.conv-item-del {
  flex-shrink: 0; width: 56rpx; height: 56rpx;
  display: flex; align-items: center; justify-content: center;
  margin-left: 12rpx; border-radius: 50%;
  transition: background 0.15s, opacity 0.15s;
  opacity: 0.78;
}
.conv-item-del:active { background: rgba(0,0,0,0.06); }
.conv-item.active .conv-item-del { opacity: 1; }
.conv-del-icon { width: 32rpx; height: 32rpx; }

/* ── Notifications ── */
.notify-stack {
  position: fixed; top: calc(env(safe-area-inset-top) + 16rpx); right: 20rpx;
  z-index: 300; width: 480rpx;
  display: flex; flex-direction: column; gap: 12rpx;
}
.notify-card {
  background: rgba(26, 29, 38, 0.92); backdrop-filter: blur(12px);
  color: #fff; border-radius: var(--r-lg); padding: 20rpx 24rpx;
  box-shadow: var(--shadow-lg); animation: slideIn 0.28s ease-out;
}
@keyframes slideIn { from { transform: translateX(110%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
.notify-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10rpx; }
.notify-title { font-size: 24rpx; font-weight: 600; }
.notify-close { font-size: 24rpx; opacity: 0.6; padding: 8rpx; }
.notify-body { font-size: 27rpx; line-height: 1.5; }
.notify-time { margin-top: 10rpx; font-size: 21rpx; opacity: 0.5; }

/* ── Header ── */
.header {
  position: sticky; top: 0; z-index: 100;
  padding: calc(env(safe-area-inset-top) + 20rpx) 28rpx 20rpx;
  background: linear-gradient(180deg, var(--c-surface) 0%, rgba(255,255,255,0.95) 100%);
  backdrop-filter: blur(16px);
  border-bottom: 1rpx solid var(--c-border-light);
}
.header-row { display: flex; align-items: center; justify-content: space-between; }
.header-left { display: flex; align-items: center; gap: 14rpx; }
.header-title { font-size: 34rpx; font-weight: 700; color: var(--c-text); }
.header-right { flex-shrink: 0; }

.status-dot {
  width: 14rpx; height: 14rpx; border-radius: 50%;
  background: var(--c-text-4);
}
.status-dot.on {
  background: var(--c-accent);
  box-shadow: 0 0 0 4rpx rgba(16,185,129,0.18);
  animation: pulse 2s infinite;
}
@keyframes pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.15)} }

.history-btn {
  height: 56rpx; padding: 0 20rpx; border-radius: var(--r-md);
  border: 1rpx solid var(--c-border); background: var(--c-surface);
  display: flex; align-items: center; justify-content: center;
}
.history-btn-text { font-size: 24rpx; font-weight: 600; color: var(--c-text-2); }

.header-sub { display: flex; align-items: center; justify-content: space-between; margin-top: 12rpx; }
.header-caption { font-size: 22rpx; color: var(--c-text-3); }
.header-stats { display: flex; gap: 10rpx; }
.stat-pill {
  font-size: 21rpx; font-weight: 600; color: var(--c-text-2);
  background: var(--c-bg); padding: 6rpx 14rpx;
  border-radius: var(--r-full);
}

.guest-bar {
  margin-top: 12rpx; font-size: 24rpx; color: var(--c-primary);
  padding: 12rpx 20rpx; background: var(--c-primary-light);
  border-radius: var(--r-sm); font-weight: 500;
}

/* ── Template Board ── */
.tpl-board { padding: 16rpx 24rpx 4rpx; }
.tpl-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 12rpx;
}
.tpl-card {
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
  padding: 16rpx 8rpx; border-radius: var(--r-md);
  background: var(--c-surface); border: 1rpx solid var(--c-border-light);
  transition: transform 0.12s;
}
.tpl-card:active { transform: scale(0.95); }
.tpl-emoji { font-size: 32rpx; }
.tpl-name { font-size: 22rpx; font-weight: 600; color: var(--c-text-2); }

.tpl-chip-row { margin-top: 12rpx; width: 100%; white-space: nowrap; }
.tpl-chip-inner { display: inline-flex; gap: 10rpx; }
.tpl-chip {
  display: inline-flex; height: 48rpx; padding: 0 16rpx;
  align-items: center; border-radius: var(--r-full);
  background: var(--c-primary-light);
  color: var(--c-primary-dark); font-size: 21rpx; font-weight: 500;
  flex-shrink: 0;
}

/* ── Log Stream ── */
.log-list { padding: 20rpx 28rpx; padding-bottom: 200rpx; }
.log-entry { margin-bottom: 20rpx; }

.log-cmd {
  display: flex; align-items: flex-start; gap: 12rpx;
  padding: 16rpx 20rpx; background: var(--c-bg);
  border-radius: var(--r-md); border-left: 6rpx solid var(--c-primary);
}
.log-prompt {
  font-size: 28rpx; font-weight: 700; color: var(--c-primary);
  line-height: 1.6; flex-shrink: 0; font-family: Menlo, Consolas, monospace;
}
.log-cmd-body { flex: 1; min-width: 0; }
.log-cmd-text { font-size: 28rpx; color: var(--c-text); line-height: 1.6; word-break: break-word; }
.log-cmd-images { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 8rpx; }
.log-cmd-img { width: 120rpx; height: 120rpx; border-radius: 10rpx; background: var(--c-border); }
.log-time { font-size: 20rpx; color: var(--c-text-4); flex-shrink: 0; margin-top: 6rpx; }
.log-time-right { display: block; text-align: right; margin-top: 8rpx; padding-right: 8rpx; }

.log-result-wrap { padding-left: 20rpx; }
.log-result {
  padding: 20rpx 24rpx; border-radius: var(--r-lg);
}
.log-result-rich { display: block; font-size: 27rpx; line-height: 1.75; color: var(--c-text); word-break: break-word; }
.log-result-images { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 12rpx; }
.bubble-image { width: 200rpx; height: 200rpx; border-radius: var(--r-sm); background: var(--c-bg); }

.log-result-pending { min-width: 180rpx; border-style: dashed; border-color: var(--c-border); }
.typing-line { display: flex; align-items: center; gap: 14rpx; }
.typing-label { font-size: 27rpx; color: var(--c-text-2); }
.typing-dots { display: inline-flex; align-items: center; gap: 4rpx; }
.typing-dot {
  font-size: 36rpx; line-height: 1; color: var(--c-primary);
  animation: blink 1.1s infinite ease-in-out;
}
.typing-dot.dot-2 { animation-delay: 0.15s; }
.typing-dot.dot-3 { animation-delay: 0.3s; }
@keyframes blink { 0%,80%,100%{opacity:0.2;transform:translateY(0)} 40%{opacity:1;transform:translateY(-4rpx)} }

/* ── Composer ── */
.composer {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: rgba(255,255,255,0.96); backdrop-filter: blur(20px);
  border-top: 1rpx solid var(--c-border-light);
  padding: 10rpx 20rpx; z-index: 200;
}

.preview-area { padding-bottom: 16rpx; }
.preview-list { width: 100%; white-space: nowrap; }
.preview-inner { display: inline-flex; gap: 14rpx; }
.preview-item { position: relative; }
.preview-image { width: 112rpx; height: 112rpx; border-radius: var(--r-md); border: 1rpx solid var(--c-border-light); }
.preview-remove {
  position: absolute; top: -10rpx; right: -10rpx;
  width: 36rpx; height: 36rpx; background: rgba(0,0,0,0.55);
  border-radius: 50%; color: #fff; display: flex; align-items: center; justify-content: center;
}
.remove-x { font-size: 28rpx; line-height: 1; margin-top: -2rpx; }

.input-area { display: flex; align-items: flex-end; gap: 10rpx; }
.img-btn {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: var(--c-bg); display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.img-btn:active { background: var(--c-border); }
.icon-img { width: 36rpx; height: 36rpx; }

.input-wrap {
  flex: 1; min-width: 0;
  background: var(--c-bg); border-radius: 32rpx;
  padding: 12rpx 22rpx; min-height: 64rpx;
  border: 1rpx solid var(--c-border-light);
  box-sizing: border-box;
}
.input-box {
  width: 100%; font-size: 28rpx; line-height: 1.45;
  color: var(--c-text); padding: 0; margin: 0;
  min-height: 36rpx; max-height: 160rpx;
}

.send-btn {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: var(--c-border); display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; transition: all 0.18s;
}
.send-btn:active { transform: scale(0.92); }
.send-btn.active {
  background: linear-gradient(135deg, var(--c-primary) 0%, var(--c-primary-dark) 100%);
  box-shadow: 0 4rpx 16rpx rgba(79,110,247,0.3);
}
.icon-send { width: 30rpx; height: 30rpx; }

.guide-board {
  margin: 16rpx 24rpx 8rpx;
  padding: 20rpx;
  border: 1rpx solid var(--c-border-light);
}

.guide-board.is-waiting {
  opacity: 0.72;
  background: #f3f4f6;
}

.guide-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--c-text);
}

.guide-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--c-text-3);
}

.onboarding-chip-list {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.onboarding-chip {
  padding: 0 18rpx;
  height: 52rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--c-primary-light);
  color: var(--c-primary-dark);
  font-size: 22rpx;
  font-weight: 600;
}

.onboarding-chip.disabled {
  background: #e5e7eb;
  color: #9ca3af;
}

.onboarding-input-row {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.onboarding-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  border-radius: 18rpx;
  border: 1rpx solid var(--c-border-light);
  background: var(--c-bg);
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  color: var(--c-text);
}

.onboarding-input.disabled {
  background: #e5e7eb;
  color: #9ca3af;
}

.onboarding-placeholder {
  color: var(--c-text-4);
}

.onboarding-send-btn {
  width: 144rpx;
  height: 72rpx;
  font-size: 24rpx;
  border-radius: 18rpx !important;
}

.onboarding-send-btn.disabled {
  background: #9ca3af !important;
  border-color: #9ca3af !important;
  color: #ffffff !important;
}

.onboarding-waiting {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.wait-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--c-primary);
  animation: waitPulse 1s ease-in-out infinite;
}

.onboarding-waiting-text {
  font-size: 22rpx;
  color: var(--c-text-3);
}

@keyframes waitPulse {
  0%, 100% { opacity: 0.4; transform: scale(0.9); }
  50% { opacity: 1; transform: scale(1.1); }
}
