# Production template (copy to server env file, e.g. /opt/pai/.env)
DB_PASSWORD=replace_with_strong_db_password
OPENAI_API_KEY=replace_with_real_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
VISION_MODEL=gpt-4o

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_POLLING_ENABLED=false
TELEGRAM_POLLING_INTERVAL=2
TELEGRAM_POLLING_TIMEOUT=25
TELEGRAM_POLLING_LIMIT=50

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_RECEIVE_ID_TYPE=open_id

BRIDGE_BASE_URL=http://bridge
ONEBOT_BASE_URL=http://napcat:3000
ONEBOT_ACCESS_TOKEN=
GEWECHAT_BASE_URL=http://gewechat:2531
GEWECHAT_APP_ID=
GEWECHAT_TOKEN=

# Miniapp backend credentials (must match your miniapp account)
MINIAPP_APP_ID=wx_your_real_appid
MINIAPP_APP_SECRET=your_real_app_secret
MINIAPP_SUBSCRIBE_TEMPLATE_ID=
MINIAPP_PAGE_PATH=pages/chat/index
MINIAPP_LANG=zh_CN
MINIAPP_SUBSCRIBE_CONTENT_KEY=thing1
MINIAPP_SUBSCRIBE_TIME_KEY=time2

DATABASE_URL=postgresql+asyncpg://pai_user:replace_with_strong_db_password@db:5432/pai_db
DATABASE_URL_SYNC=postgresql+psycopg2://pai_user:replace_with_strong_db_password@db:5432/pai_db
REDIS_URL=redis://redis:6379/0
SCHEDULER_ENABLED=true
ALLOW_MEMORY_CHECKPOINTER_FALLBACK=false

MCP_FETCH_ENABLED=true
MCP_FETCH_URL=
MCP_FETCH_API_KEY=
WEB_SEARCH_API_URL=https://open.bigmodel.cn/api/paas/v4/web_search
WEB_SEARCH_API_KEY=
WEB_SEARCH_ENGINE=search_pro_sogou
WEB_SEARCH_INTENT=true
WEB_SEARCH_CONTENT_SIZE=medium
MCP_SEARCH_URL=
MCP_SEARCH_API_KEY=
MCP_SEARCH_FALLBACK_URL=
MCP_SEARCH_FALLBACK_API_KEY=
MCP_FETCH_TIMEOUT_SEC=30
MCP_FETCH_DEFAULT_MAX_LENGTH=5000

LONG_TERM_MEMORY_ENABLED=true
LONG_TERM_MEMORY_RETRIEVE_MODE=full_inject
LONG_TERM_MEMORY_MIN_CONFIDENCE=0.75
LONG_TERM_MEMORY_MAX_WRITE_ITEMS=6
LONG_TERM_MEMORY_RETRIEVE_LIMIT=6
LONG_TERM_MEMORY_RETRIEVE_SCAN_LIMIT=80
LONG_TERM_MEMORY_DEFAULT_TTL_DAYS=180
MEMORY_INDEX_WORKER_ENABLED=false
MEMORY_INDEX_WORKER_INTERVAL_SEC=30
MEMORY_INDEX_WORKER_BATCH_SIZE=32
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
MEMORY_EMBEDDING_DIM=1536
MEMORY_VECTOR_VERSION=1
MEMORY_MILVUS_ENABLED=false
MEMORY_MILVUS_URI=
MEMORY_MILVUS_TOKEN=
MEMORY_MILVUS_COLLECTION=memory_text_v1
MILVUS_SEARCH_LIMIT=24

ADMIN_TOKEN=replace_with_admin_token
DEDUP_TTL_SECONDS=86400

JWT_SECRET=replace_with_long_random_secret_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=10080
